#DESCRIPTION
Automatic Pair Injection (Photoionization) Test

#INITFROMSWMF
F                       initFromSWMF

#GEOMETRY
-1.0                    xMin
 1.0                    xMax
-1.0                    yMin
 1.0                    yMax
-1.0                    zMin
 1.0                    zMax

#NCELL
20                      nCellX
8                       nCellY
8                       nCellZ

#MAXBLOCKSIZE
20                      maxBlockSizeX
8                       maxBlockSizeY
8                       maxBlockSizeZ

#PERIODICITY
T                       isPeriodicX
T                       isPeriodicY
T                       isPeriodicZ

#SOLVEEM
F                       solveEM

#TESTCASE
pickup                  testCase
1.0                     Ey
1.0                     Bz
-0.1                    xMin
 0.1                    xMax

#PLASMA
3                       nSpecies
1.0                     mass
1.0                     charge
16.0                    mass
1.0                     charge
0.01                    mass
-1.0                    charge

#EXOSPHERE
1                       iSpecies
exponential             NeutralProfile
1.0                     r0
0.0                     ExobaseRadius
0.0                     ShadowRadius
8.0e23                  TotalProductionRate
100.0                   nMacroParticlesPerDt
1.0e11                  n0
0.03                    H0
0.0                     T0
0.0                     k0

#EXOSPHERE
2                       iSpecies
exponential             NeutralProfile
1.0                     r0
0.0                     ExobaseRadius
0.0                     ShadowRadius
2.0e23                  TotalProductionRate
100.0                   nMacroParticlesPerDt
1.0e11                  n0
0.03                    H0
0.0                     T0
0.0                     k0

#TIMESTEPPING
T                       useFixedDt
0.1                     dt

#NORMALIZATION
1.0                     lNormSI
1.0                     uNormSI

#MONITOR
1                       dnReport

#SAVEPLOT
5                                 nPlot
3d fluid amrex pic                plotString
-1                                dn
1                                 dt
1                                 dx
3d particles0 amrex pic           plotString
-1                                dn
1                                 dt
1                                 dx
3d particles1 amrex pic           plotString
-1                                dn
1                                 dt
1                                 dx
3d particles2 amrex pic           plotString
-1                                dn
1                                 dt
1                                 dx
z=0 fluid real4 pic               plotString
-1                                dn
1                                 dt
-1                                dx

#DIAGNOSTIC
T                    doParticleDiag
F                    doFieldDiag

#STOP
-1                      MaxIter
0.2                     TimeMax

#RUN
