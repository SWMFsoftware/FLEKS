#DESCRIPTION
0D "Box" Equilibrium Test (Chemical/Kinetic Balance)

#INITFROMSWMF
F                       initFromSWMF

#GEOMETRY
-1.0                    xMin
 1.0                    xMax
-1.0                    yMin
 1.0                    yMax
-1.0                    zMin
 1.0                    zMax

#NCELL
8                       nCellX
8                       nCellY
 8                      nCellZ

#MAXBLOCKSIZE
8                       maxBlockSizeX
8                       maxBlockSizeY
8                       maxBlockSizeZ

#PERIODICITY
T                       isPeriodicX
T                       isPeriodicY
T                       isPeriodicZ

#SOLVEEM
F                       solveEM

#PLASMA
1                       nSpecies
1.0                     mass
1.0                     charge

#EXOSPHERE
1                       iSpecies
exponential             NeutralProfile
1.0                     r0
1.0                     ExobaseRadius
0.0                     ShadowRadius
1.0e24                  TotalProductionRate
1000.0                  nMacroParticlesPerDt
1.0e11                  n0
0.03                    H0
200.0                   T0
0.0                     k0

#TIMESTEPPING
T                       useFixedDt
0.1                     dt

#NORMALIZATION
1.0                     lNormSI
1.0                     uNormSI

#MONITOR
1                       dnReport

#STOP
-1                      MaxIter
1.0                     TimeMax

#RUN
