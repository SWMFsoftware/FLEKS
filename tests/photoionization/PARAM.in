#DESCRIPTION
2D Photoionization Shadow Cylinder for Mars with Chamberlain Exosphere

#INITFROMSWMF
F                       initFromSWMF

#GEOMETRY
-9.0e6                  xMin
 9.0e6                  xMax
-9.0e6                  yMin
 9.0e6                  yMax
-0.5                    zMin
 0.5                    zMax

#NCELL
32                      nCellX
32                      nCellY
1                       nCellZ

#MAXBLOCKSIZE
32                      maxBlockSizeX
32                      maxBlockSizeY
1                       maxBlockSizeZ

#PERIODICITY
T                       isPeriodicX
T                       isPeriodicY
T                       isPeriodicZ

#SOLVEEM
T                       solveEM

#ELECTRON
-100                    electronChargePerMass

#PLASMA
2                       nSpecies
1.0                     mass        Species 0: H+ (light background)
1.0                     charge
16.0                    mass        Species 1: O+ (heavy, gets exosphere source)
1.0                     charge

#UNIFORMSTATE
5.0                     rho [amu/cc]   Species 0 background
0.0                     ux [km/s]
0.0                     uy [km/s]
0.0                     uz [km/s]
10000.0                 T [K]
1.0e-12                 rho [amu/cc]   Species 1 background (tiny seed, < photoionization)
0.0                     ux [km/s]
0.0                     uy [km/s]
0.0                     uz [km/s]
10000.0                 T [K]
5.0e-9                  bx [T]
0.0                     by [T]
0.0                     bz [T]
0.0                     ex [V/m]
0.0                     ey [V/m]
0.0                     ez [V/m]

#SOURCE
T                       useSource

#BODYSIZE
3.0e6                   radius        Mars-like planet radius

#EXOSPHERE
Chamberlain             typeProfile
2                       nComponent
1.0e10                  n0            H component: light species, large scale height
2000.0e3                H0
300.0                   T0
0.0                     k0
5.0e10                  n0            O component: heavy species, small scale height
300.0e3                 H0
300.0                   T0
0.0                     k0

#PHOTOIONIZATION
2                       nComponent
1.0e-4                  nuPhoto0      H photoionization rate at surface
1.0e-4                  nuPhoto0      O photoionization rate at surface

#SHADOWCYLINDER
1.0                     solarDirX     Sun in +X direction (dayside)
0.0                     solarDirY
0.0                     solarDirZ
3.0e6                   radius        shadow cylinder
9.0e6                   halfHeight    finite height along anti-solar dir (3x Rp)

#TIMESTEPPING
T                       useFixedDt
0.1                     dt

#NORMALIZATION
1000.0                  lNormSI
1.0e6                   uNormSI

#MONITOR
1                       dnReport

#PARTICLES
4                       nParticle per cell in X
4                       nParticle per cell in Y
1                       nParticle per cell in Z

#COMOVING
T                       solvePartInCoMov
5                       nSmoothBackGroundU

#UPWINDE
T                       useUpwindE
1                       limiterTheta

#UPWINDB
T                       doSmoothB
1                       theta

#SMOOTHJ
T
1
0.5

#EFIELDSOLVER
1.0e-6                  EFieldTol
200                     EFieldIter

#DIVE
T
1

#SAVEPLOT
1                       nPlot
z=0 var ascii planet    plotString
-1                      dn
1.0                     dt           save once at end (t = TimeMax)
1                       dx
rhoS1                   NameVars

#STOP
10                      MaxIter
1.0                     TimeMax

#RUN
