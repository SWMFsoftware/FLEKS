#DESCRIPTION
Electron Impact Ionization Test for H+O with Chamberlain Neutral Profile

#INITFROMSWMF
F                       initFromSWMF

#GEOMETRY
-1e3                    xMin
 1e3                    xMax
-1.0                    yMin
 1.0                    yMax
-1.0                    zMin
 1.0                    zMax

#NCELL
32                      nCellX
1                       nCellY
1                       nCellZ

#MAXBLOCKSIZE
32                      maxBlockSizeX
1                       maxBlockSizeY
1                       maxBlockSizeZ

#PERIODICITY
T                       isPeriodicX
T                       isPeriodicY
T                       isPeriodicZ

#SOLVEEM
T                       solveEM

#ELECTRON
-100                    electronChargePerMass

#PLASMA
3                       nSpecies
0.01                    mass        Species 0: electron
-1.0                    charge
1.0                     mass        Species 1: H+ (light ion background)
1.0                     charge
16.0                    mass        Species 2: O+ (heavy, gets exosphere source)
1.0                     charge

#UNIFORMSTATE
0.05                    rho [amu/cc]   Species 0: electron (quasi-neutral, hot for Te)
0.0                     ux [km/s]
0.0                     uy [km/s]
0.0                     uz [km/s]
100000.0                T [K]         High T for impact ionization
5.0                     rho [amu/cc]   Species 1: H+ background
0.0                     ux [km/s]
0.0                     uy [km/s]
0.0                     uz [km/s]
100000.0                T [K]
0.1                     rho [amu/cc]   Species 2: O+ background (low density seed)
0.0                     ux [km/s]
0.0                     uy [km/s]
0.0                     uz [km/s]
10000.0                 T [K]
5.0e-9                  bx [T]
0.0                     by [T]
0.0                     bz [T]
0.0                     ex [V/m]
0.0                     ey [V/m]
0.0                     ez [V/m]

#SOURCE
T                       useSource

#BODYSIZE
500.0                   radius

#EXOSPHERE
Chamberlain             typeProfile
2                       nComponent
1.0e10                  n0            H component: base density
1000.0                  H0            H component: scale height parameter (large)
100.0                   T0
0.0                     k0
3.0e10                  n0            O component: base density
100.0                   H0            O component: scale height parameter (small)
150.0                   T0
0.0                     k0

#ELECTRONIMPACT
2                       nComponent
13.6                    eIon          H: ionization energy [eV]
3.0e-8                  Acoeff        H: Voronov A [cm^3/s]
0.39                    Kcoeff        H: Voronov K
0.23                    Xcoeff        H: Voronov X
13.6                    eIon          O: ionization energy [eV]
1.0e-8                  Acoeff        O: Voronov A [cm^3/s]
0.5                     Kcoeff        O: Voronov K
0.3                     Xcoeff        O: Voronov X

#TIMESTEPPING
T                       useFixedDt
0.1                     dt

#NORMALIZATION
1000.0                  lNormSI
1.0e6                   uNormSI

#MONITOR
1                       dnReport

#PARTICLES
4                       nParticle per cell in X
1                       nParticle per cell in Y
1                       nParticle per cell in Z

#COMOVING
T                       solvePartInCoMov
5                       nSmoothBackGroundU

#UPWINDE
T                       useUpwindE
1                       limiterTheta

#UPWINDB
T                       doSmoothB
1                       theta

#SMOOTHJ
T
1
0.5

#EFIELDSOLVER
1.0e-6                  EFieldTol
200                     EFieldIter

#DIVE
T
1

#SAVEPLOT
0                       nPlot

#STOP
10                      MaxIter
1.0                     TimeMax

#RUN
